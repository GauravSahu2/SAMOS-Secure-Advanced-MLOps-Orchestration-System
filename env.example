# ================================================================================
# SAMOS: Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's already in .gitignore
# ================================================================================

# ── API Server ────────────────────────────────────────────────────────────────
PORT=7860

# ── MLflow Tracking ───────────────────────────────────────────────────────────
# Option A: Local SQLite (default, free, zero setup)
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Option B: DagsHub (free for public repos — https://dagshub.com)
# MLFLOW_TRACKING_URI=https://dagshub.com/YOUR_USERNAME/SAMOS.mlflow
# MLFLOW_TRACKING_USERNAME=YOUR_DAGSHUB_USERNAME
# MLFLOW_TRACKING_PASSWORD=YOUR_DAGSHUB_TOKEN

# ── Redis (Optional) ─────────────────────────────────────────────────────────
# Option A: Local Docker Redis (default)
REDIS_URL=redis://localhost:6379

# Option B: Upstash Redis (free tier: 10K cmds/day — https://upstash.com)
# REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_ENDPOINT.upstash.io:6380

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme_on_first_login

# ── Apache NiFi (real-time data ingestion layer) ─────────────────────────────
# Ingests raw bytes (Kafka, S3, IoT) → Bronze Lake
# Start: docker-compose --profile nifi up nifi  |  Access: https://localhost:8443
NIFI_USER=admin
NIFI_PASS=change_this_strong_password_123!

# ── Apache Airflow (pipeline orchestration layer) ─────────────────────────────
# Schedules & monitors the 25-phase SAMOS pipeline as Airflow DAG tasks.
# Complements NiFi: NiFi ingests → Airflow orchestrates pipeline phases.
# Start: docker-compose --profile airflow up airflow  |  Access: http://localhost:8080
AIRFLOW_SECRET_KEY=change_me_to_a_random_32char_string
AIRFLOW_ADMIN_PASSWORD=change_me_on_first_login

# ── Hugging Face (for CD workflow + model downloads) ─────────────────────────
# Get token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_YOUR_TOKEN_HERE
HF_SPACE_ID=YourHFUsername/SAMOS

# ── SonarCloud (free for public repos — https://sonarcloud.io) ────────────────
SONAR_TOKEN=your_sonarcloud_token
SONAR_HOST_URL=https://sonarcloud.io

# ── Codecov (free code coverage reporting — https://codecov.io) ───────────────
CODECOV_TOKEN=your_codecov_token

# ── Unified Logging ────────────────────────────────────────────────────────────
# Controls log verbosity across all SAMOS modules (uses Python logging)
# Values: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
