# 🏹 SAMOS: .gitignore
# High-Assurance exclusion list

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
.env

# AI Models & Memory (Proprietary - DO NOT COMMIT)
models/*.bin
models/*.pt
models/*.onnx
models/*.json
memory/neural_vault.json
forge.lock

# Data & Logs
data/*.csv
data/*.parquet
*.log
artifacts/*.log

# IDE & OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Build & Audit
dist/
build/
*.egg-info/
htmlcov/
.coverage
coverage.xml
sbom.json
audit_bundle.zip
